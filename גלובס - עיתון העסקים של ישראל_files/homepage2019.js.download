/* lazyload.js (c) Lorenzo Giuliani
* MIT License (http://www.opensource.org/licenses/mit-license.html)
*
* expects a list of:
* `<img src="blank.gif" data-src="my_image.png" width="600" height="400" class="lazy">`
*/
$(function () {
    var $q = function (q, res) {
        if (document.querySelectorAll) {
            res = document.querySelectorAll(q);
        } else {
            var d = document
	            , a = d.styleSheets[0] || d.createStyleSheet();
            a.addRule(q, 'f:b');
            for (var l = d.all, b = 0, c = [], f = l.length; b < f; b++)
                l[b].currentStyle.f && c.push(l[b]);

            a.removeRule(0);
            res = c;
        }
        return res;
    }
	    , addEventListener = function (evt, fn) {
	        window.addEventListener
	          ? this.addEventListener(evt, fn, false)
	          : (window.attachEvent)
	            ? this.attachEvent('on' + evt, fn)
	            : this['on' + evt] = fn;
	    }
	    , _has = function (obj, key) {
	        return Object.prototype.hasOwnProperty.call(obj, key);
	    }
	    ;

    function loadImage(el, fn) {
        var img = new Image()
	      , src = el.getAttribute('data-src');
        img.onload = function () {
            if (!!el.parent)
                el.parent.replaceChild(img, el)
            else
                el.src = src;

            fn ? fn() : null;
        }
        if(src.indexOf('https://res.cloudinary.com/globes/image/upload/')>-1){

             if(src.indexOf('/upload/v1')>-1){
                src=src.replace('/upload/v1','/upload/f_auto/v1');
             }else {
                src=src.replace('/v1',',f_auto/v1');

                }
        }
        img.src = src;
    }

    function elementInViewport(el) {
        var rect = el.getBoundingClientRect()

        return (
	       rect.top >= 0
	    && rect.left >= 0
	    && rect.top <= (window.innerHeight || document.documentElement.clientHeight)
	    )
    }

    var images = new Array()
	      , query = $q('img.lazy')
	      , processScroll = function () {
	          for (var i = 0; i < images.length; i++) {
	              if (elementInViewport(images[i])) {
	                  loadImage(images[i], function () {
	                      images.splice(i, 1);
	                  });
	              }
	          };
	      }
	      ;
    // Array.prototype.slice.call is not callable under our lovely IE8
    for (var i = 0; i < query.length; i++) {
        images.push(query[i]);
    };

    processScroll();
    addEventListener('scroll', processScroll);

});


function makeCustomSlider(_itemClass, _containerID, _scrollerID, _srightID, _sleftID, _paddingWidth) {
    function cs(_itemClass, _containerID, _scrollerID, _srightID, _sleftID, _paddingWidth) {
        var paddingWidth = _paddingWidth;
        var itemsCount = 0;
        var itemWidth = 0;
        var scrollerWidth = 0;
        var containerWidth = 0;
        var itemClass = _itemClass;
        var containerID = _containerID;
        var scrollerID = _scrollerID;
        var srightID = _srightID;
        var sleftID = _sleftID;
        var scrollSize = 0;
        var itemsInFrame = 0;
        var animating = false;

        itemsCount = $("#" + containerID + " ." + itemClass).length;
        if (itemsCount > 0) {

            itemWidth = $("#" + containerID + " ." + itemClass)[0].offsetWidth;
            containerWidth = (itemWidth + paddingWidth) * itemsCount; // $("#" + containerID)[0].offsetWidth
            $("#" + containerID).css('width', containerWidth);
            scrollerWidth = $("#" + scrollerID)[0].offsetWidth
            scrollSize = itemWidth + paddingWidth;
            itemsInFrame = parseInt(Math.round(Math.floor(scrollerWidth / (itemWidth + paddingWidth))));

            $("#" + containerID).attr('ic', itemsCount);
            $("#" + containerID).attr('iw', itemWidth);
            $("#" + containerID).attr('cw', containerWidth);
            $("#" + containerID).attr('pw', paddingWidth);
            $("#" + containerID).attr('ss', scrollSize);
            $("#" + containerID).attr('iif', itemsInFrame);

            $("#" + srightID).click(function () {
                if (!animating) {
                    animating = true;
                    var ic = 1 * $("#" + containerID).attr('ic');
                    var iif = 1 * $("#" + containerID).attr('iif');
                    var iw = 1 * $("#" + containerID).attr('iw');
                    var cw = 1 * $("#" + containerID).attr('cw'); // $("#" + containerID).parent().width();  //
                    var pw = 1 * $("#" + containerID).attr('pw');
                    var ss = 1 * $("#" + containerID).attr('ss');

                    if (Math.abs(parseInt($("#" + containerID).css('right').replace("auto", "0"))) + (iif * (iw + pw)) < cw) {
                        $("#" + containerID).animate({ 'right': '-=' + ss + 'px' }, 'slow', function () {
                            animating = false;
                            if (!(Math.abs(parseInt($("#" + containerID).css('right').replace("auto", "0"))) + (iif * (iw + pw)) < cw)) {
                                $("#" + srightID).addClass("notactive");
                            } else {
                                $("#" + srightID).removeClass("notactive");
                            }
                            if (!(parseInt($("#" + containerID).css('right').replace("auto", "0")) != 0 && !isNaN(parseInt($("#" + containerID).css('right'))))) {
                                $("#" + sleftID).addClass("notactive");
                            } else {
                                $("#" + sleftID).removeClass("notactive");
                            }
                        });
                    } else {
                        animating = false;

                    }
                }
            });

            $("#" + sleftID).click(function () {
                if (!animating) {
                    animating = true;
                    var ic = 1 * $("#" + containerID).attr('ic');
                    var iif = 1 * $("#" + containerID).attr('iif');
                    var iw = 1 * $("#" + containerID).attr('iw');
                    var cw = 1 * $("#" + containerID).attr('cw');
                    var pw = 1 * $("#" + containerID).attr('pw');
                    var ss = 1 * $("#" + containerID).attr('ss');
                    if (parseInt($("#" + containerID).css('right').replace("auto", "0")) != 0 && !isNaN(parseInt($("#" + containerID).css('right')))) {
                        $("#" + containerID).animate({ 'right': '+=' + scrollSize + 'px' }, 'slow', function () {
                            animating = false;
                            if (!(parseInt($("#" + containerID).css('right').replace("auto", "0")) != 0 && !isNaN(parseInt($("#" + containerID).css('right'))))) {
                                $("#" + sleftID).addClass("notactive");
                            } else {
                                $("#" + sleftID).removeClass("notactive");
                            }
                            if (!(Math.abs(parseInt($("#" + containerID).css('right').replace("auto", "0"))) + (iif * (iw + pw)) < cw)) {
                                $("#" + srightID).addClass("notactive");
                            } else {
                                $("#" + srightID).removeClass("notactive");
                            }
                        });
                    } else {
                        animating = false;
                    }
                }
            });

            if (!(parseInt($("#" + containerID).css('right').replace("auto", "0")) != 0 && !isNaN(parseInt($("#" + containerID).css('right'))))) {
                $("#" + sleftID).addClass("notactive");
            } else {
                $("#" + sleftID).removeClass("notactive");
            }
            if (!(Math.abs(parseInt($("#" + containerID).css('right').replace("auto", "0"))) + (itemsInFrame * (itemWidth + paddingWidth)) < containerWidth)) {
                $("#" + srightID).addClass("notactive");
            } else {
                $("#" + srightID).removeClass("notactive");
            }
        }
    }

    var test = new cs(_itemClass, _containerID, _scrollerID, _srightID, _sleftID, _paddingWidth);
}


/* Client-side access to querystring name=value pairs
	Version 1.2.3
	22 Jun 2005
	Adam Vandenberg
*/
function Querystring(qs) { // optionally pass a querystring to parse
	this.params = new Object()
	this.get=Querystring_get
	
	if (qs == null)
	    qs = location.search.substring(1)
	

	if (qs.length == 0) return

// Turn <plus> back to <space>
// See: http://www.w3.org/TR/REC-html40/interact/forms.html#h-17.13.4.1
	qs = qs.replace(/\+/g, ' ')
	var args = qs.split('&') // parse out name/value pairs separated via &
	
// split out each name=value pair
	for (var i=0;i<args.length;i++) {
	    var value;
	    var pos = args[i].indexOf('=')
	    if(pos > 0 )
	    {
	        var name = args[i].substring(0,pos)
	        var value = args[i].substring(pos+1)            
            this.params[name] = unescape(value)
	    }
		
	}
}

function Querystring_get(key, default_) {
	// This silly looking line changes UNDEFINED to NULL
	if (default_ == null) default_ = null;
	
	var value=this.params[key]
	if (value==null) value=default_;
	
	return value
}

