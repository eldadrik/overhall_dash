var isFirstVideo = true;
function iframeclick() {
    document.getElementById("mainClip").contentWindow.document.body.onclick = function () {
        if (isFirstVideo) {
            ga('homePage.send', 'event', 'וידאו', 'click', 'כתבה ראשית');
            isFirstVideo = false;
            g.StopPageReload = true;
        }
    }
}

function ChangePrimaryVideo(docId, id) {
    //main box
    isFirstVideo = false;
    var allBox = document.getElementsByClassName('box');

    for (var i = 0; i < allBox.length; i++) {
        allBox[i].classList.remove("active");
    }

    //small box
    var box = document.getElementById("box_" + docId);
    box.classList.add("active");


    //changing local js 
    var newTitle = box.getElementsByClassName("ClipText")[0].innerHTML;
    var cluster = box.getElementsByClassName("tagitSmall")[0];
    var newPoster = box.getElementsByClassName("magazine_boxIMG")[0].src
    mediaId = $(box).attr("data-mediaid");
        
    jw_docId = parseInt(docId)
    jw_poster = newPoster;
    jw_title = newTitle;
    
    //replace big
    document.getElementById("mainClipText").innerHTML = newTitle;
    //replace tagit
    if (cluster != undefined)
        document.getElementById("tagitBig").innerHTML = cluster.outerHTML;
    else
        document.getElementById("tagitBig").innerHTML = ""; 
    
    var pl = jwplayer().getPlaylist();

    if (typeof (pl) != "undefined" && pl.length > id) {

        var jwConfig = jwplayer().getConfig();
        jwConfig.sharing.link = "https://www.globes.co.il/news/article.aspx?did=" + docId;

        jwplayer().playlistItem(id);
        return;
    }
    
    //update the player
    var jw = jwplayer($(".jwplayer").attr('id'));
    var jwConfig = jw.getConfig();
    //jwConfig.autostart = true;
