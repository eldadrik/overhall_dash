var protocol_and_host = get_protocol_and_host()
var isBitcoin = getParameterByName("bitcoin");

function getParameterByName(name) {
    var url = window.location.href;
    name = name.replace(/[\[\]]/g, "\\$&");
    var regex = new RegExp("[?&]" + name + "(=([^&#]*)|&|#|$)"),
        results = regex.exec(url);
    if (!results) return null;
    if (!results[2]) return '';
    return decodeURIComponent(results[2].replace(/\+/g, " "));
}

function get_protocol_and_host() {
    var caller_from_querystring = location.search.replace(/.*&caller=([^&]*).*/, '$1')
	if (caller_from_querystring.match(/www\.maariv\.co\.il/i)) {return '//www.globes.co.il'}
	return caller_from_querystring.length < location.search.length ? location.protocol + '//' + caller_from_querystring : ''
}
