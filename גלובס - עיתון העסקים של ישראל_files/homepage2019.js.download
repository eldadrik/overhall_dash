    //jwConfig.image = newPoster;

    var pid = (jw.getConfig()).pid;

    var selectedItem = [{
        "sharing.link": "/news/article.aspx?did=" + docId,
        "file" : "//cdn.jwplayer.com/videos/" + mediaId + "-P6P7OjCF.mp4", //"//cdn.jwplayer.com/videos/ktQB7Y84-P6P7OjCF.mp4", //"//content.jwplatform.com/videos/"+ mediaId + "-" + jw_player + ".mp4", 
