function objIndex(instrumentId,last,percentage){
    this.id = instrumentId;
    this.last = last;
    this.percentage = percentage;
    this.mark = false;
}
var arrIndex = new Array();
function PopulateArray(continent,type,rowNumber ,instrumentID,last,percentage)
{
    if( arrIndex.length-1 < rowNumber) {
        arrIndex[rowNumber] = new objIndex(instrumentID,last,percentage)
    }
    else {
        if(arrIndex[rowNumber].id == instrumentID ) {
            if(arrIndex[rowNumber].last!=last || arrIndex[rowNumber].percentage!=percentage) {
                arrIndex[rowNumber].mark = true;
            }
            arrIndex[rowNumber].last = last
            arrIndex[rowNumber].percentage = percentage;
        }
    }
}
function Marker(marker_id, isDefault)
{
    var oName = document.getElementById("tdName_" + marker_id)
    var oPercentage = document.getElementById("tdPercentage_" + marker_id)
    var oLast =  document.getElementById("tdLast_" + marker_id)
    var oArrow =  document.getElementById("tdArrow_" + marker_id)

    if(oName==null) return;
    var oNameClassName = oName.className

    if(isDefault && oNameClassName!="") {  //unmark
        if(oName.className=="TrayTopRightTD2") {
            oPercentage.className = "TrayTopLeftTD2";
           oLast.className = "TrayBottomLeftBlackTD2" ;
           oArrow.className = "TrayBottomLeftBlackTD2" ;
        }
        else{
            oPercentage.className = "TrayTopLeftTDOff2";
            oLast.className = "";
            oArrow.className = "";
        }
    }
    else{   //mark
        if(oNameClassName=="TrayTopRightTD2") {//selected item
            oPercentage.className = "TrayTopLeftTDMark2";
            oLast.className = "TrayBottomLeftBlackTDMark2";
            oArrow.className = "TrayBottomLeftBlackTDMark2";
        }
        else {                                  //not selected items
            oPercentage.className = "TrayTopLeftTDOffMArk2";
            oLast.className = "TrayTopLeftTDOffMArk2";
            oArrow.className = "TrayBottomLeftBlackTDMark2";
        }
    }

}
function CheckPopulate()
{
    for(var i=0; i<arrIndex.length;i++)
    {
        if(arrIndex[i].mark == true)
        {
            Marker(i,false);
            setTimeout('Marker('+i+',true)',700);
            arrIndex[i].mark = false;
        }
    }
}


function setDefaultTab()
{
    for(var itab = 1; itab <= iTabCount; itab++)
    {
        var sName = "tab1_inner" + itab;
        //if(itab == 1)document.getElementById(sName).className = "G_PremiumTabsOn";
        //else document.getElementById(sName).className = "G_PremiumTabsOff";
        if (document.getElementById(sName) == null) { continue }
        if (itab == 1) document.getElementById(sName).className = "none";
        else document.getElementById(sName).className = "none";
    }
}

var showTabFlag = "1";

function selectTab(sContinent, sType, isDefault, tabID, tab) {
	if (arguments.length < 5) {tab = 1}
	showTabFlag = tabID;

	setTimeout("GetSelectedFinanceData('" + sContinent + "','" + sType + "' , " + isDefault + " , " + tabID + " , '" + tab + "')", 400);
}

//Get Array data
function GetSelectedFinanceData(sContinent, sType, isDefault, tabID, tab) {

    if (document.getElementById('divSponsLink')) document.getElementById('divSponsLink').innerHTML = "";

	if (showTabFlag == tabID) {
		try {e_counter.count(sContinent, 'GetSelectedFinanceData', 'ta') } catch (ex) {}
		SetActiveTabPointer(tab)
		iGlobalCounter++;

		var sArrRes = null;
		document.getElementById('Graph_div_1_id').style.visibility = "visible";
		document.getElementById("imgGraph").style.display = "";
		document.getElementById("divPlaceHolder").style.display="none";
		setDefaultTab();
		document.getElementById("hidContinent").value = sContinent;
	//	document.getElementById("divPortfolio").innerHTML = "";

	//	var dp = document.getElementById("divPortfolio")
		if (tabID == 1 || tabID == 2 || tabID == 4) {
			document.getElementById('tab1_inner1').innerHTML = "מדדים";
			document.getElementById('tab1_inner2').innerHTML = "פעילות";
			document.getElementById('tab1_inner3').innerHTML = "עולות";
			document.getElementById('tab1_inner4').innerHTML = "יורדות";
			if (tabID == 1) {document.getElementById('tab1_inner5').innerHTML = "התיק שלי";}
			if (tabID == 2 || tabID == 4) {document.getElementById('tab1_inner5').innerHTML = "ישראליות";}
        }
        else if (tabID == 5)
        {
            document.getElementById('tab1_inner1').innerHTML = "מדדים";
            document.getElementById('tab1_inner2').innerHTML = "";
            document.getElementById('tab1_inner3').innerHTML = "";
            document.getElementById('tab1_inner4').innerHTML = "";
            document.getElementById('tab1_inner5').innerHTML = "";

        }
		else if(tabID == 6)
		{
		   // document.getElementById('Graph_div_1_id').style.visibility = "hidden";
		    document.getElementById('divSponsLink').innerHTML = "coinmarketcap.com";

 
		    document.getElementById('tab1_inner1').innerHTML = "";  
		    document.getElementById('tab1_inner2').innerHTML = "";
		    document.getElementById('tab1_inner3').innerHTML = "";
		    document.getElementById('tab1_inner4').innerHTML = "";
		    document.getElementById('tab1_inner5').innerHTML = "";
		}
		else {
			document.getElementById('tab1_inner1').innerHTML = "מט\"ח";
			document.getElementById('tab1_inner2').innerHTML = "";
			document.getElementById('tab1_inner3').innerHTML = "";
			document.getElementById('tab1_inner4').innerHTML = "";
			document.getElementById('tab1_inner5').innerHTML = "";
		}

        for (var itab = 1; itab <= iTabCount; itab++) {
            var sMainTabId = "tab" + itab + "_" + itab;
          //console.log(sMainTabId)
            if (document.getElementById(sMainTabId) == null) { continue }
			if (itab == tabID) {
				document.getElementById(sMainTabId).className = "Finance_Selected";
			} else {
				document.getElementById(sMainTabId).className = ""; 
			}
		}
		try{
			switch(sContinent) {
				case sTaTabName:
					sArrRes = globalfinance_arrIndicesTA;  //array from .js file
					break;
				case sWSTabName:
					sArrRes = globalfinance_arrIndicesWS;  //array from .js file
					break;
				case sUSATabName:
					sArrRes = globalfinance_arrIndicesUSA;  //array from .js file
					break;
				case sCCTabName:
					sArrRes = [] // globalfinance_arrCC;  //array from .js file
					break;
				case sEuropeTabName:
					sArrRes = globalfinance_arrIndicesEurope;  //array from .js file
					break;
				 case sAsiaTabName:
					sArrRes = globalfinance_arrIndicesAsia;  //array from .js file
					break;
			    case sDigitalCurr:
			        sArrRes = globalfinance_arrDigitalCurrencies;
			        break;
			}
		} catch(ex){
		    sArrRes = new Array();
		    console.log(ex);
		}
        if (((sContinent == sTaTabName || sContinent == sWSTabName || sContinent == sEuropeTabName) && sType == 'IndicesItem')
			|| (sContinent == sCCTabName)
		) {
		//	alert('dit (' + sType + ',' + tabID + ',0,1)')
			DrawInnerTab(sType,tabID,0,1)
		}
		else if (sContinent == sDigitalCurr)
		{
		    DrawDigitalCurrencies(sArrRes);
		}
		else {
			if(sArrRes != null) {
			//	alert('drd(' + sContinent + ',' + isDefault + ',0)')
				DrawResultData(sArrRes,sContinent,isDefault,0, sType)
			}
		}
		ChangeFinancialTabClass(document.getElementById('tab1_inner1').parentNode.parentNode)
	}
}

function ChangeBorderColor(tab_name,id)
{
    for(var itab = 1; itab <= iTabCount; itab++)
    {
       try
       {
           var sMainTabId = tab_name + itab;
           if (document.getElementById(sMainTabId) == null) { continue }
           if(itab == id){document.getElementById(sMainTabId).className = "G_WhiteBGColor";}
           else{document.getElementById(sMainTabId).className = "G_GrayBGColor"; }
       }
       catch(e){}
    }
}

