           month = (month<10)? "0"+ month : month;
           var day = (oDate.getDate()<10) ? "0" + oDate.getDate().toString() : oDate.getDate().toString();
           var minute = (oDate.getMinutes()<10) ? "0" + oDate.getMinutes().toString() : oDate.getMinutes().toString();
           var hour = (oDate.getHours()<10) ? "0" + oDate.getHours().toString() : oDate.getHours().toString();
           var author = "<div class='g_Article_Author'>"+ SpokenArticles_arr[i][3] +"</div>";
           var shortDate =  "<div class='ArticleItemPatternNoFidHomePage'>"+ day + "." + month + "." + oDate.getFullYear() + "</div>" ;
           var shortTime =  "<div class='ArticleItemPatternNoFidHomePage'>" + hour + ":" + minute +"</div>" ;
           // mostSpokenPattern came from "lib.JsGraphicTools.ArticleItemPattern"
           var mostSpokenItem = mostSpokenPattern.replace("{0}",SpokenArticles_arr[i][0])
           
           //mostSpokenItem = mostSpokenItem.replace("{2}",shortTime)
           var writerNameForAlt = SpokenArticles_arr[i][3].replace('"', '&quot;')

           var clusterTitle = ""; //SpokenArticles_arr[i][4]
