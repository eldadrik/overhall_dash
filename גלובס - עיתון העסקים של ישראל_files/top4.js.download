           mostSpokenItem = mostSpokenItem.replace("<a ", "<a title=\"מאת: " + writerNameForAlt + "\" onclick=\"ga('homePage.send', 'event', '_browse', 'Click To Article', 'Homepage - More headlines ')\"")
           document.write(mostSpokenItem)
